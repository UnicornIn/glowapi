# ───────────────────────────────────────────────────────────
# GlowUp — Plantilla de variables de entorno
# Copiar a .env (o /etc/glowup/envs/.env.<slug> en el EC2) y rellenar.
# Una BD y un proceso uvicorn por cliente.
# ───────────────────────────────────────────────────────────

# ── Base de datos (único valor que cambia siempre por cliente) ──
MONGODB_URI=
MONGODB_NAME=

# ── JWT ─────────────────────────────────────────────────────
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# ── CORS — orígenes del frontend permitidos (separados por coma) ──
CORS_ORIGINS=

# ── Email (nombres EXACTOS que lee el código) ───────────────
EMAIL_REMITENTE=
EMAIL_CONTRASENA=

# ── S3 (bucket e IAM compartidos; se aíslan por company_id) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=
AWS_PUBLIC_BASE_URL=

# ── Alegra POS (OPCIONAL — solo si el cliente factura con Alegra) ──
ALEGRA_BASE_URL=
ALEGRA_EMAIL=
ALEGRA_TOKEN=
ALEGRA_ENABLED_SEDE_ID=
ALEGRA_DEFAULT_KIND_OF_PERSON=
